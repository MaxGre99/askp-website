generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// АУТЕНТИФИКАЦИЯ 

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  role          UserRole   @default(USER)
  status        UserStatus @default(PENDING)
  approvedAt    DateTime?
  approvedBy    String?
  approver      User?      @relation("UserApprovals", fields: [approvedBy], references: [id])
  approvedUsers User[]     @relation("UserApprovals")

  news   News[]
  events Event[]
  profile Profile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum UserStatus {
  PENDING // зарегистрировался, ждёт одобрения
  ACTIVE // одобрен
  REJECTED // отклонён
  BLOCKED // заблокирован позже
}

// НОВОСТИ

model News {
  id        String  @id @default(uuid())
  title     String
  slug      String  @unique
  content   String
  image     String?
  published Boolean @default(true)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// СОБЫТИЯ

model Event {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  eventDate   DateTime
  published   Boolean  @default(true)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ПРОФИЛЬ

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

model Profile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Основные данные
  firstName      String?
  lastName       String?
  middleName     String?
  displayName    String?
  gender         Gender?
  languages      String[]        // Postgres поддерживает массивы
  maritalStatus  MaritalStatus?
  birthDate      DateTime?

  // О себе
  shortBio       String?
  fullBio        String?         // HTML из Quill

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}