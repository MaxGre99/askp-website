generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// АУТЕНТИФИКАЦИЯ 

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  role          UserRole   @default(USER)
  status        UserStatus @default(PENDING)
  approvedAt    DateTime?
  approvedBy    String?
  approver      User?      @relation("UserApprovals", fields: [approvedBy], references: [id])
  approvedUsers User[]     @relation("UserApprovals")
  membershipLevel MembershipLevel?
  membershipRank  Int      @default(999)

  news          News[]
  events        Event[]
  articles      Article[]
  profile       Profile?

   passwordResetTokens PasswordResetToken[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  BLOCKED
}

enum MembershipLevel {
  PRESIDENT
  VICE_PRESIDENT
  EXPERT
  SPECIALIST
  PSYCHOLOGIST_PRACTITIONER
  BEGINNER_SPECIALIST
  PARTNER
}

// НОВОСТИ

model News {
  id        String  @id @default(uuid())
  title     String
  slug      String  @unique
  content   String
  image     String?
  published Boolean @default(true)

  authorId  String
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// СОБЫТИЯ

model Event {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  eventDate   DateTime
  published   Boolean  @default(true)

  authorId    String
  author      User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// СТАТЬИ

model Article {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  image       String?
  published   Boolean  @default(true)

  authorId    String
  author      User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ПРОФИЛЬ

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum PhoneRefs {
  CALL
  WHATSAPP
  TELEGRAM
}

model Profile {
  userId          String @id
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Основные данные
  avatarUrl       String?
  firstName       String?
  lastName        String?
  middleName      String?
  displayName     String?
  gender          Gender?
  city            String?
  languages       String[]        // Postgres поддерживает массивы
  maritalStatus   MaritalStatus?
  birthDate       DateTime?

  // О себе
  shortBio        String?
  fullBio         String?         // HTML из Quill

  // Контакты
  phone           String?
  telegramUser    String?
  telegramChannel String?
  vkUrl           String?
  website         String?
  phoneRefs       PhoneRefs[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ДОНАТЕРЫ

model Donater {
  id          String   @id @default(uuid())
  name        String
  description String
  image       String?
}

// ЗАКАЗЫ И ТОВАРЫ

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  contentLink String   // ссылка на курс — только серверная сторона!
  price       Int      // в рублях
  images      String[] // массив URL для слайдера
  published   Boolean  @default(false)

//   orders      Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

